{
    "name": "codesnap-plus",
    "displayName": "CodeSnap-plus",
    "description": "📸 Take beautiful screenshots of your code in VS Code! And you can hightlight the line just by click.",
    "version": "1.4.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/huibizhang/CodeSnap-plus"
    },
    "publisher": "huibizhang",
    "icon": "icon.png",
    "license": "MIT",
    "engines": {
        "vscode": "^1.120.0"
    },
    "keywords": [
        "screenshot",
        "snippet",
        "snap",
        "clipboard",
        "share",
        "polacode",
        "carbon",
        "codesnap"
    ],
    "categories": [
        "Other"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "codesnap-plus.start",
                "title": "CodeSnap-plus 📸"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "codesnap-plus.start"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "CodeSnap",
            "properties": {
                "codesnap-plus.backgroundColor": {
                    "scope": "resource",
                    "type": "string",
                    "default": "#abb8c3",
                    "description": "The background color of the snippet's container"
                },
                "codesnap-plus.boxShadow": {
                    "scope": "resource",
                    "type": "string",
                    "default": "rgba(0, 0, 0, 0.55) 0px 20px 68px",
                    "description": "The CSS box-shadow for the snippet"
                },
                "codesnap-plus.containerPadding": {
                    "scope": "resource",
                    "type": "string",
                    "default": "3em",
                    "description": "The padding for the snippet's container"
                },
                "codesnap-plus.roundedCorners": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Use rounded corners for the window"
                },
                "codesnap-plus.showWindowControls": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Display OS X style window controls"
                },
                "codesnap-plus.showWindowTitle": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Display window title with open folder / file name"
                },
                "codesnap-plus.showLineNumbers": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Display line numbers"
                },
                "codesnap-plus.realLineNumbers": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Start from the selection's line number instead of 1"
                },
                "codesnap-plus.transparentBackground": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Use a transparent background when taking the screenshot"
                },
                "codesnap-plus.target": {
                    "scope": "resource",
                    "type": "string",
                    "enum": [
                        "container",
                        "window"
                    ],
                    "default": "container",
                    "description": "Take the shot with or without the container"
                },
                "codesnap-plus.shutterAction": {
                    "scope": "resource",
                    "type": "string",
                    "enum": [
                        "save",
                        "copy"
                    ],
                    "default": "save",
                    "description": "The behavior of the shutter button"
                },
                "codesnap-plus.toolMode": {
                    "scope": "resource",
                    "type": "string",
                    "enum": [
                        "simple",
                        "advanced"
                    ],
                    "default": "advanced",
                    "description": "The mode of tool, mode \"simple\" will only show the shutter button"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "npm run compile:extension && npm run compile:webview",
        "compile:extension": "tsc -p .",
        "compile:webview": "tsc -p tsconfig.webview.json --noEmit && esbuild webview/src/index.ts --bundle --format=iife --outfile=webview/dist/index.js && npx tailwindcss -i style.css -o ./webview/style.css",
        "check": "npm run compile && npm run lint",
        "lint": "eslint .",
        "tw": "npx tailwindcss -i style.css -o ./webview/style.css --watch"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@types/vscode": "^1.120.0",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    },
    "dependencies": {
        "dom-to-image-even-more": "^1.0.4"
    }
}