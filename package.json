{
    "name": "codesnap-neo",
    "displayName": "CodeSnap Neo",
    "description": "📸 Take beautiful screenshots of your code in VS Code! And you can highlight the line just by clicking.",
    "version": "2.4.2",
    "repository": {
        "type": "git",
        "url": "https://github.com/VeriTas-arch/codesnap-neo"
    },
    "publisher": "ovolab-veritas",
    "icon": "icon.png",
    "license": "BSD 3-Clause",
    "engines": {
        "vscode": "^1.120.0"
    },
    "keywords": [
        "screenshot",
        "snippet",
        "snap",
        "clipboard",
        "share",
        "polacode",
        "carbon",
        "codesnap"
    ],
    "categories": [
        "Other"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "codesnap-neo.start",
                "title": "CodeSnap Neo 📸"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "codesnap-neo.start"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "CodeSnap Neo",
            "properties": {
                "codesnap-neo.backgroundColor": {
                    "scope": "resource",
                    "type": "string",
                    "default": "#abb8c3",
                    "description": "The background color of the snippet's container"
                },
                "codesnap-neo.boxShadow": {
                    "scope": "resource",
                    "type": "string",
                    "default": "rgba(0, 0, 0, 0) 0px 0px 0px",
                    "description": "The CSS box-shadow for the snippet"
                },
                "codesnap-neo.containerPadding": {
                    "scope": "resource",
                    "type": "string",
                    "default": "3em",
                    "description": "The padding for the snippet's container"
                },
                "codesnap-neo.roundedCorners": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Use rounded corners for the window"
                },
                "codesnap-neo.showWindowControls": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Display OS X style window controls"
                },
                "codesnap-neo.showWindowTitle": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Display window title with open folder / file name"
                },
                "codesnap-neo.showLineNumbers": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Display line numbers"
                },
                "codesnap-neo.realLineNumbers": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Start from the selection's line number instead of 1"
                },
                "codesnap-neo.transparentBackground": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Use a transparent background when taking the screenshot"
                },
                "codesnap-neo.target": {
                    "scope": "resource",
                    "type": "string",
                    "enum": [
                        "container",
                        "window"
                    ],
                    "default": "window",
                    "description": "Take the shot with or without the container"
                },
                "codesnap-neo.shutterAction": {
                    "scope": "resource",
                    "type": "string",
                    "enum": [
                        "save",
                        "copy"
                    ],
                    "default": "save",
                    "description": "The behavior of the shutter button"
                },
                "codesnap-neo.toolMode": {
                    "scope": "resource",
                    "type": "string",
                    "enum": [
                        "simple",
                        "advanced"
                    ],
                    "default": "advanced",
                    "description": "The mode of tool, mode \"simple\" will only show the shutter button"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p . && npm run compile:webview",
        "compile:webview": "tsc -p tsconfig.webview.json --noEmit && esbuild webview/src/index.ts --bundle --format=iife --outfile=webview/dist/index.js && npm run copy:domtoimage && npm run build:css",
        "copy:domtoimage": "node -e \"require('fs').copyFileSync('node_modules/dom-to-image-even-more/dist/dom-to-image-more.min.js','webview/dist/dom-to-image-more.min.js')\"",
        "build:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i style.css -o ./webview/style.css",
        "check": "npm run compile && npm run lint",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@types/vscode": "^1.120.0",
        "cross-env": "^10.1.0",
        "esbuild": "^0.28.1",
        "eslint": "^10.5.0",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "dom-to-image-even-more": "^1.0.4"
    }
}
