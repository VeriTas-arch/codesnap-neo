{
    "name": "codesnap-neo",
    "displayName": "CodeSnap Neo",
    "description": "Take screenshots of code in vscode for presenting.",
    "version": "2.4.5",
    "repository": {
        "type": "git",
        "url": "https://github.com/VeriTas-arch/codesnap-neo"
    },
    "publisher": "ovolab-veritas",
    "icon": "image/icon.png",
    "license": "BSD 3-Clause",
    "engines": {
        "vscode": "^1.120.0"
    },
    "keywords": [
        "screenshot",
        "snippet",
        "clipboard",
        "share",
        "codesnap"
    ],
    "categories": [
        "Other"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "codesnap-neo.start",
                "title": "CodeSnap Neo"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "codesnap-neo.start"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "CodeSnap Neo",
            "properties": {
                "codesnap-neo.showLineNumbers": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Display line numbers"
                },
                "codesnap-neo.realLineNumbers": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": true,
                    "description": "Start from the selection's line number instead of 1"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p . && npm run compile:webview",
        "compile:webview": "node scripts/prepare-webview-dist.mjs && tsc -p tsconfig.webview.json && npm run build:css",
        "build:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i webview/src/style.css -o ./webview/style.css",
        "check": "npm run compile && npm run lint",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@types/vscode": "^1.120.0",
        "cross-env": "^10.1.0",
        "eslint": "^10.5.0",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    }
}
